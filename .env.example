# Copy to `.env` or `.env.local` and fill in values. Restart `npm run dev` after changes.

# --- ElevenLabs Conversational AI (voice coach) — required for /api/elevenlabs/signed-url
# API key: ElevenLabs dashboard → Profile → API Key
ELEVENLABS_API_KEY=
# Agent ID: Agents → your agent → URL contains agent_...
ELEVENLABS_AGENT_ID=

# Optional: websocket (default) or webrtc
# ELEVENLABS_CONNECTION_TYPE=websocket

# Optional: Unity camera GameObject name if not "Main Camera"
# NEXT_PUBLIC_UNITY_CAMERA_OBJECT=Main Camera
